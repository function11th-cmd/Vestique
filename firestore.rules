rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userEmail() {
      return request.auth.token.email;
    }

    function normalizedEmail(email) {
      return email.replace('.', '_').replace('@', '_');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.uid != null
        && (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid))
           && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adm_acs == 1)
          || exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        );
    }

    function isShortText(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    function isHttpsUrl(value) {
      return value is string && value.matches('^https://.{4,}$');
    }

    function canWriteAgain(lastWriteAtMs, minIntervalMs) {
      return !(lastWriteAtMs is int) || (request.time.toMillis() - lastWriteAtMs) > minIntervalMs;
    }

    function productCreateIsValid() {
      return request.resource.data.keys().hasOnly([
        'name', 'price', 'desc', 'image', 'imageBack',
        'stock', 'category', 'status', 'createdAt', 'updatedAt'
      ])
      && isShortText(request.resource.data.name, 2, 100)
      && request.resource.data.price is number
      && request.resource.data.price >= 0
      && request.resource.data.price <= 999999
      && (request.resource.data.desc == null || isShortText(request.resource.data.desc, 0, 500))
      && isHttpsUrl(request.resource.data.image)
      && (request.resource.data.imageBack == '' || isHttpsUrl(request.resource.data.imageBack))
      && request.resource.data.stock is int
      && request.resource.data.stock >= 0
      && request.resource.data.stock <= 10000
      && request.resource.data.category in ['football', 'cricket', 'basketball', 'shorts']
      && request.resource.data.status in ['in-stock', 'out-of-stock']
      && request.resource.data.createdAt is int
      && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is int);
    }

    function productUpdateIsValid() {
      return request.resource.data.keys().hasOnly([
        'name', 'price', 'desc', 'image', 'imageBack',
        'stock', 'category', 'status', 'createdAt', 'updatedAt'
      ])
      && isShortText(request.resource.data.name, 2, 100)
      && request.resource.data.price is number
      && request.resource.data.price >= 0
      && request.resource.data.price <= 999999
      && (request.resource.data.desc == null || isShortText(request.resource.data.desc, 0, 500))
      && isHttpsUrl(request.resource.data.image)
      && (request.resource.data.imageBack == '' || isHttpsUrl(request.resource.data.imageBack))
      && request.resource.data.stock is int
      && request.resource.data.stock >= 0
      && request.resource.data.stock <= 10000
      && request.resource.data.category in ['football', 'cricket', 'basketball', 'shorts']
      && request.resource.data.status in ['in-stock', 'out-of-stock']
      && request.resource.data.createdAt is int
      && request.resource.data.updatedAt is int
      && canWriteAgain(resource.data.updatedAt, 1000);
    }

    function isOwnerOrderRead() {
      return isSignedIn() && resource.data.email == userEmail();
    }

    function orderCreateIsValid() {
      return request.resource.data.keys().hasAll([
        'id', 'date', 'email', 'status', 'items', 'total', 'createdAt'
      ])
      && isShortText(request.resource.data.id, 4, 40)
      && isShortText(request.resource.data.date, 4, 80)
      && request.resource.data.email is string
      && request.resource.data.email == userEmail()
      && request.resource.data.status in ['Processing', 'Confirmed', 'Shipped', 'Delivered', 'Cancelled']
      && request.resource.data.items is list
      && request.resource.data.items.size() > 0
      && request.resource.data.items.size() <= 100
      && request.resource.data.total is number
      && request.resource.data.total >= 0
      && request.resource.data.createdAt is int;
    }

    function isUserCartId(cartId) {
      return isSignedIn() && cartId == ('user_' + normalizedEmail(userEmail()));
    }

    function guestCartCreateIsValid(cartId) {
      return !isSignedIn()
        && cartId.matches('^guest_[A-Za-z0-9_-]{16,128}$')
        && request.resource.data.keys().hasOnly(['items', 'cartId', 'updatedAt'])
        && request.resource.data.cartId == cartId
        && request.resource.data.items is list
        && request.resource.data.items.size() <= 100
        && request.resource.data.updatedAt is int;
    }

    function guestCartUpdateIsValid(cartId) {
      return !isSignedIn()
        && cartId.matches('^guest_[A-Za-z0-9_-]{16,128}$')
        && request.resource.data.keys().hasOnly(['items', 'cartId', 'updatedAt'])
        && request.resource.data.cartId == cartId
        && request.resource.data.items is list
        && request.resource.data.items.size() <= 100
        && request.resource.data.updatedAt is int
        && canWriteAgain(resource.data.updatedAt, 1000);
    }

    // Product catalog: public read, admin write
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && productCreateIsValid();
      allow update: if isAdmin() && productUpdateIsValid();
      allow delete: if isAdmin();
    }

    // User profiles with admin access flag
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // User can create own profile only with adm_acs = 0.
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['adm_acs', 'email', 'name', 'createdAt', 'updatedAt'])
        && request.resource.data.adm_acs is int
        && request.resource.data.adm_acs == 0
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.createdAt is int
        && request.resource.data.updatedAt is int;

      // Only admin (via Firebase Console/Admin SDK) can elevate or edit other user profiles.
      allow update, delete: if isAdmin();
    }

    // Carts: owner-only access
    match /carts/{cartId} {
      allow read, delete: if isUserCartId(cartId) || (!isSignedIn() && cartId.matches('^guest_[A-Za-z0-9_-]{16,128}$'));
      allow create: if isUserCartId(cartId) || guestCartCreateIsValid(cartId);
      allow update: if isUserCartId(cartId) || guestCartUpdateIsValid(cartId);
    }

    // Orders: owner can create/read own orders, admin can manage all
    match /orders/{orderId} {
      allow create: if isSignedIn() && orderCreateIsValid();
      allow read: if isAdmin() || isOwnerOrderRead();

      // Admin can update/delete any order.
      allow update, delete: if isAdmin();

      // Signed-in users can cancel their own pending orders (Processing/Confirmed).
      allow update: if isSignedIn()
        && request.auth.token.email == resource.data.email
        && resource.data.status in ['Processing', 'Confirmed']
        && request.resource.data.status == 'Cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }
  }
}
