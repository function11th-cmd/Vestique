rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Product catalog: public read, admin write
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admin registry: only admins can manage
    match /admins/{email} {
      allow read, write: if isAdmin();
    }

    // Carts: owner-only access
    match /carts/{cartId} {
      // Compatibility: signed-in users can use user_* carts; guests can use guest_* carts.
      // For strict owner-only control, migrate carts to UID-based document IDs.
      allow read, create, update, delete: if (isSignedIn() && cartId.matches('^user_.*$'))
        || (!isSignedIn() && cartId.matches('^guest_[A-Za-z0-9]+$'));
    }

    // Orders: owner can create/read own orders, admin can manage all
    match /orders/{orderId} {
      // Compatibility: tracking page currently allows public read by order id.
      allow create: if true;
      allow read: if true;
      allow update, delete: if isAdmin();
    }
  }
}
